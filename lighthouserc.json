{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost/index.html",
        "http://localhost/cookie-policy.html",
        "http://localhost/privacy-policy.html",
        "http://localhost/terms-of-service.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "blockedUrlPatterns": ["*.zeffy.com/*", "*.zeffy.org/*"]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.98 }],
        "categories:best-practices": ["warn", { "minScore": 0.96 }],
        "categories:seo": ["error", { "minScore": 0.98 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 3500000 }],
        "resource-summary:media:size": ["error", { "maxNumericValue": 1000000 }],
        "resource-summary:script:size": ["warn", { "maxNumericValue": 1200000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 1000000 }],
        "resource-summary:font:size": ["warn", { "maxNumericValue": 500000 }]
      }
    }
  }
}
